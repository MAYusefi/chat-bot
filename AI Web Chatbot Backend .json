    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.first().json;\n\nconst rawMessage = String(input.message || '').trim();\nconst rawSession = String(input.sessionId || '').trim();\nconst rawToken = String(input.authToken || '').trim();\nconst sharedSecret = String(input.sharedSecret || '').trim();\nconst preferredLanguage = String(input.preferredLanguage || 'fa-AF').trim().slice(0, 20) || 'fa-AF';\n\nconst sessionId = rawSession.replace(/[^a-zA-Z0-9_-]/g, '').slice(0, 128) || `session-${Date.now()}`;\n\nlet validationStatus = 'valid';\nlet statusCode = 200;\nlet error = '';\n\nif (!rawMessage) {\n  validationStatus = 'invalid';\n  statusCode = 400;\n  error = 'پیام خالی است.';\n} else if (rawMessage.length > 2000) {\n  validationStatus = 'invalid';\n  statusCode = 413;\n  error = 'طول پیام بیش از حد مجاز است (حداکثر 2000 کاراکتر).';\n} else if (!sharedSecret || sharedSecret === 'CHANGE_THIS_TOKEN' || sharedSecret === 'YOUR_SECURE_TOKEN_HERE') {\n  validationStatus = 'invalid';\n  statusCode = 500;\n  error = 'توکن امنیتی ورک‌فلو تنظیم نشده است.';\n} else if (rawToken !== sharedSecret) {\n  validationStatus = 'invalid';\n  statusCode = 401;\n  error = 'توکن امنیتی نامعتبر است.';\n}\n\nconst staticData = getWorkflowStaticData('global');\nif (!staticData.rateLimiter || typeof staticData.rateLimiter !== 'object') {\n  staticData.rateLimiter = {};\n}\n\nconst now = Date.now();\nconst windowMs = 60 * 1000;\nconst maxPerWindow = 20;\nconst staleAfterMs = 10 * 60 * 1000;\n\nfor (const [sid, bucket] of Object.entries(staticData.rateLimiter)) {\n  if (!bucket || typeof bucket !== 'object' || now - Number(bucket.windowStart || 0) > staleAfterMs) {\n    delete staticData.rateLimiter[sid];\n  }\n}\n\nlet rateBucket = staticData.rateLimiter[sessionId] || { windowStart: now, count: 0, resetAt: now + windowMs };\nif (now - Number(rateBucket.windowStart || 0) > windowMs) {\n  rateBucket = { windowStart: now, count: 0, resetAt: now + windowMs };\n}\n\nif (validationStatus === 'valid') {\n  rateBucket.count += 1;\n  staticData.rateLimiter[sessionId] = rateBucket;\n\n  if (rateBucket.count > maxPerWindow) {\n    validationStatus = 'invalid';\n    statusCode = 429;\n    const resetIn = Math.ceil((rateBucket.resetAt - now) / 1000);\n    error = `تعداد درخواست شما زیاد است. لطفاً ${resetIn} ثانیه صبر کنید.`;\n  }\n}\n\nconst remaining = Math.max(0, maxPerWindow - Number(rateBucket.count || 0));\nconst resetInSeconds = Math.ceil((rateBucket.resetAt - now) / 1000);\n\nreturn [{\n  json: {\n    ...input,\n    message: rawMessage,\n    sessionId,\n    preferredLanguage,\n    validationStatus,\n    statusCode,\n    error,\n    rateLimit: {\n      limit: maxPerWindow,\n      remaining,\n      resetIn: resetInSeconds > 0 ? resetInSeconds : 0,\n      windowMs\n    }\n  }\n}];"
      },
