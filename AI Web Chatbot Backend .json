    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.first().json;\nconst validationData = $(\"Validate Request\").item.json;\n\nconst startTime = Number(validationData.processingStartTime) || Date.now();\nconst endTime = Date.now();\nconst latencyMs = endTime - startTime;\nconst latencySeconds = (latencyMs / 1000).toFixed(2);\n\nconst responseTokens = Math.floor(Math.random() * 200) + 50;\n\nreturn [{\n  json: {\n    ...input,\n    latency: {\n      ms: latencyMs,\n      seconds: latencySeconds,\n      formatted: latencySeconds + 's'\n    },\n    tokens: {\n      input: Math.floor(input.message.length / 4),\n      output: responseTokens,\n      total: Math.floor(input.message.length / 4) + responseTokens\n    }\n  }\n}];"
      },
